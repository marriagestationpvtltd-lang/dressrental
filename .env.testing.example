APP_NAME="Dress Rental TEST"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL — cPanel shared hosting, testing database) ──────────────
# cPanel maa: MySQL Databases → cpanelusername_dressrental_test database banaunus.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpanelusername_dressrental_test
DB_USERNAME=cpanelusername_testuser
DB_PASSWORD=your_test_db_password

# ── Admin account for test database ─────────────────────────────────────────
ADMIN_EMAIL=admin@dressrental.com
ADMIN_PASSWORD=password
ADMIN_PHONE=9800000001

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="test@dressrental.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── eSewa Payment Gateway (sandbox — testing only) ───────────────────────────
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_SANDBOX=true

# ── Khalti Payment Gateway (sandbox — testing only) ──────────────────────────
KHALTI_SECRET_KEY=test_secret_key_dc74e0fd57cb46cd93832aee0a390234
KHALTI_PUBLIC_KEY=test_public_key_dc74e0fd57cb46cd93832aee0a390234
KHALTI_SANDBOX=true
